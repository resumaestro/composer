{
  "$schema_note": "Central, code-free tuning surface for Composer. Edit values here; src reads this at bundle time.",
  "version": 1,
  "cache": {
    "keyPrefix": "research",
    "ttlSeconds": 604800,
    "ttlHumanReadable": "7 days"
  },
  "browser": {
    "navigationTimeoutMs": 20000,
    "waitUntil": "domcontentloaded",
    "maxTextChars": 20000,
    "maxHeadings": 60,
    "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
  },
  "embedding": {
    "model": "@cf/qwen/qwen3-embedding-0.6b",
    "dimensions": 1024
  },
  "vector": {
    "topK": 3,
    "returnMetadata": "all",
    "minScore": 0.0,
    "blockedMetadataKeys": ["secret", "credential", "raw_code", "token", "api_key"]
  },
  "modelRouting": {
    "tier": "edge",
    "edge": {
      "provider": "workers-ai",
      "model": "@cf/meta/llama-3-8b-instruct",
      "maxTokens": 1200,
      "temperature": 0.2
    },
    "premium": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-20241022",
      "anthropicVersion": "2023-06-01",
      "maxTokens": 4096,
      "temperature": 0.2,
      "requiresGateway": true
    }
  }
}
