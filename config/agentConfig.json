{
  "name": "composer",
  "displayName": "Conductor (migrated)",
  "description": "Auto-assembles a tailored job application end to end: queries vector evidence, researches the company against hard criteria, and synthesizes a one-page resume. Human-gated before any external submit. Migrated from the Hyperagent Conductor agent.",
  "origin": {
    "platform": "hyperagent",
    "legacyAgentId": "cmqbq25zb167m06adozw7bqxv",
    "legacyAgentName": "Conductor",
    "migratedFrom": ["job-vector", "job-research", "job-resume"]
  },
  "persona": {
    "executionMode": "confirm",
    "humanGate": true,
    "neverFabricate": true,
    "sourceOfTruth": "source.yml in R2 (read-only)"
  },
  "model": {
    "provider": "cloudflare-workers-ai",
    "embeddingModel": "@cf/qwen/qwen3-embedding-0.6b",
    "embeddingDim": 1024,
    "resumeModel": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    "legacyOrchestratorModel": "opus-latest"
  },
  "vectorize": {
    "binding": "VECTOR_INDEX",
    "defaultIndex": "source-code-rag",
    "metric": "cosine",
    "dimensions": 1024,
    "indices": [
      { "name": "job-company", "purpose": "company research cache" },
      { "name": "job-people", "purpose": "interviewer / people research cache" },
      { "name": "job-role", "purpose": "role research cache" },
      { "name": "source-code-rag", "purpose": "supporting technical project evidence for the resume" }
    ]
  },
  "r2": {
    "binding": "JOB_SOURCE",
    "bucket": "job-source",
    "keys": {
      "sourceOfTruth": "source.yml",
      "baseResume": "BASE_RESUME.html",
      "tuningLedger": "tuning/insights.json"
    }
  },
  "hardCriteria": {
    "minCompUsd": 200000,
    "requiresWebTech": true,
    "avoidPrimaryLanguages": ["python", "go"],
    "commute": { "driveMaxSeconds": 1500, "transitMaxSeconds": 2400 }
  },
  "pipeline": ["queryVectorDatabase", "researchCompany", "buildResume"]
}
