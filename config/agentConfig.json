{
  "name": "resumaestro-composer",
  "displayName": "Composer",
  "description": "Auto-assembles a tailored job application end to end: queries vector evidence, researches the company against hard criteria, and synthesizes a one-page resume. Human-gated before any external submit.",
  "persona": {
    "executionMode": "confirm",
    "humanGate": true,
    "neverFabricate": true,
    "sourceOfTruth": "source/experience.yml in R2 (read-only)"
  },
  "models": {
    "fast": "claude-haiku-4-5",
    "standard": "claude-sonnet-4-6",
    "powerful": "claude-sonnet-4-6"
  },
  "model": {
    "provider": "cloudflare-workers-ai",
    "embeddingModel": "@cf/qwen/qwen3-embedding-0.6b",
    "embeddingDim": 1024,
    "resumeModel": "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  },
  "vectorize": {
    "indices": [
      { "binding": "VECTOR_INDEX",           "index": "source-code-rag",          "purpose": "candidate experience chunks (read-only)" },
      { "binding": "RESUMAESTRO_COMPANIES",   "index": "resumaestro-companies",    "purpose": "company research cache (written by researchCompany)" },
      { "binding": "RESUMAESTRO_TEAMMEMBERS", "index": "resumaestro-teammembers",  "purpose": "people research cache (written by future people-research skill)" },
      { "binding": "RESUMAESTRO_ROLES",       "index": "resumaestro-roles",        "purpose": "role/job-description cache (written by buildResume)" }
    ],
    "metric": "cosine",
    "dimensions": 1024
  },
  "r2": {
    "binding": "RESUMAESTRO_SOURCE",
    "bucket": "resumaestro-source",
    "keys": {
      "sourceOfTruth": "source/experience.yml",
      "baseResume": "source/resume.html",
      "research": "research/{jobId}/raw.json",
      "brief": "research/{jobId}/brief.md",
      "resume": "resumes/{jobId}/v{n}.md",
      "listing": "listings/{jobId}.html"
    }
  },
  "d1": {
    "binding": "DB",
    "database": "resumaestro-pipeline",
    "tables": ["research", "resumes"]
  },
  "hardCriteria": {
    "minCompUsd": 200000,
    "requiresWebTech": true,
    "avoidPrimaryLanguages": ["python", "go"],
    "commute": { "driveMaxSeconds": 1500, "transitMaxSeconds": 2400 }
  }
}
