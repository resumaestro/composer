# Resumaestro Composer — local debugging variables
#
# For `wrangler dev`, copy the secret-style values into a `.dev.vars` file
# (same KEY=VALUE format) — Wrangler loads .dev.vars automatically and it is
# gitignored. The non-secret vars below already live in wrangler.toml [vars];
# this file documents every key the worker reads so local runs are reproducible.

# --- Workers AI ---------------------------------------------------------------
# Embedding model used for Vectorize queries (1024-dim, cosine in the legacy stack).
EMBEDDING_MODEL="@cf/qwen/qwen3-embedding-0.6b"

# --- Outbound callback seam (resumaestro framework) ---------------------------
# Background orchestration POSTs its result to ${CALLBACK_BASE_URL}/jobs/:id/result
CALLBACK_BASE_URL="https://resumaestro.example.com"
# Optional bearer token attached to the result webhook as Authorization: Bearer <token>
CALLBACK_TOKEN="dummy-callback-token"

# --- Premium model routing (optional) -----------------------------------------
# Base URL of a Cloudflare AI Gateway. When set, the premium tier proxies the
# external provider through the gateway to get automatic response caching.
# Example: https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway_slug>
AI_GATEWAY_URL="https://gateway.ai.cloudflare.com/v1/00000000000000000000000000000000/composer"
# API key for the premium provider (Anthropic by default). Dummy value for local dev.
PREMIUM_API_KEY="sk-ant-dummy-key-for-local-debugging-only"
