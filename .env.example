# Composer Worker - local development environment variables
#
# Copy to `.dev.vars` for `wrangler dev` (or `.env`) and fill in real values locally.
# NEVER commit real secrets. Production secrets are set with: wrangler secret put <NAME>
#
# Workers AI, Vectorize, and R2 are configured as bindings in wrangler.toml. They need no key
# locally: `wrangler dev` uses your authenticated Cloudflare account.

# --- Model overrides (optional; defaults live in wrangler.toml [vars]) ---
EMBEDDING_MODEL="@cf/qwen/qwen3-embedding-0.6b"
RESUME_MODEL="@cf/meta/llama-3.3-70b-instruct-fp8-fast"

# --- Company research: web search API (Tavily-compatible) ---
SEARCH_API_URL="https://api.tavily.com/search"
# Dummy value. Set the real key via: wrangler secret put TAVILY_API_KEY
TAVILY_API_KEY="tvly-000000000000000000000000000000"

# --- Commute worker (geoapify) ---
COMMUTE_WORKER_URL="https://geoapify-commute-worker.cameronaziz.workers.dev"
# Dummy value. Set the real key via: wrangler secret put ROZZY_KEY
ROZZY_KEY="rozzy_0000000000000000000000"

# --- Async callback flow (optional) ---
# Base URL the worker POSTs results to: <CALLBACK_BASE_URL>/jobs/:id/result
# Leave empty to run the pipeline synchronously and return the result inline.
CALLBACK_BASE_URL=""
